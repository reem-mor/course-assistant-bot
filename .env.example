# Oz VeRuach Course Assistant — environment template.
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# IMPORTANT: keep comments on their own lines. A blank var with a trailing inline comment
# (e.g. `KEY=   # note`) is parsed by python-dotenv as the comment text -> truthy garbage.

# ---------------------------------------------------------------------------
# Core runtime  (environment: development | production | test)
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=true
HEALTH_HOST=0.0.0.0
# The worker (split mode) uses HEALTH_PORT + 1.
HEALTH_PORT=8080

# ---------------------------------------------------------------------------
# Telegram. Two-tier roles (comma-separated numeric IDs); owners imply admin.
# Collect IDs with the built-in /myid command.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_botfather_token_here
OWNER_TELEGRAM_IDS=
ADMIN_TELEGRAM_IDS=
# RUN_MODE: polling (dev) | webhook (prod)
RUN_MODE=polling
WEBHOOK_URL=
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_LISTEN_PORT=8443

# ---------------------------------------------------------------------------
# Google Drive + Gmail. v1 decision: OAuth with Re'em's account (read + gmail.send).
# Mint a refresh token with: uv run python scripts/get_google_token.py
# Set the OAuth app to Internal / In-production so the refresh token doesn't expire.
# GOOGLE_SA_JSON is an optional later upgrade (service account path).
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_SA_JSON=
GOOGLE_API_KEY=
COURSE_DRIVE_FOLDER_ID=1GfQBI1btQSoyMLQ7z-_aE4xBnObsO2wO
# The only Drive write path (admin upload filing). Off by default; needs a write scope.
DRIVE_WRITE_ENABLED=false

# ---------------------------------------------------------------------------
# Homework email routing. To = Alex; CC = Sagy (comma-separated for two addresses).
#   HW_TO_EMAIL=kalex7878@gmail.com
#   HW_CC_EMAIL=sagy.galor@fursa.org.il,sagy.galor@portlandtrust.org.il
# ---------------------------------------------------------------------------
HW_TO_EMAIL=
HW_CC_EMAIL=
# SMTP fallback (e.g. smtp.gmail.com + a Google App Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# LLM providers. At least one required; OpenAI also powers ASR + embeddings.
# Missing providers fall back gracefully.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Model registry overrides (optional): "provider:model" in {anthropic, openai, google}.
# ---------------------------------------------------------------------------
MODEL_ROUTER=
MODEL_CONVERSATIONAL=
MODEL_SUMMARIZER=
MODEL_EMAIL_WRITER=
MODEL_RECOMMENDATIONS=
ASR_MODEL=gpt-4o-mini-transcribe

# ---------------------------------------------------------------------------
# RAG / recommendations
# ---------------------------------------------------------------------------
EMBEDDINGS_MODEL=text-embedding-3-small
WEB_SEARCH_ENABLED=false
RAG_TOP_K=4

# ---------------------------------------------------------------------------
# Notifications / worker / single-process
# RUN_SCHEDULER_IN_BOT=true runs the scheduler inside the bot (single process).
# ---------------------------------------------------------------------------
BROADCAST_RATE_PER_SEC=25
DRIVE_POLL_MINUTES=15
RUN_SCHEDULER_IN_BOT=true
COURSE_WEBSITE_URL=https://oz-ve-ruach-journey.lovable.app/
SCHEDULE_REFRESH_HOURS=168
PRECOMPUTE_HOUR=3
HEAVY_OP_COOLDOWN_SEC=30

# ---------------------------------------------------------------------------
# Datastore / vector store. For Supabase use the asyncpg driver:
#   SUPABASE_DB_URL=postgresql+asyncpg://postgres:<pw>@<host>:5432/postgres
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/oz_veruach.db
SUPABASE_DB_URL=
